{
  "name": "football-predictor-backend",
  "version": "1.0.0",
  "description": "Football betting prediction engine - Dixon-Coles model",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.scripts.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{js,ts}\" \"scripts/**/*.{js,ts}\" --max-warnings=0",
    "test": "npm run build && node --test test/**/*.test.js",
    "test:ci": "node --test test/**/*.test.js",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:eurobet-headed": "node scripts/run-eurobet-headed.js",
    "smoke:eurobet": "ts-node-dev --transpile-only --exit-child scripts/smoke-eurobet.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.33",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.57.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
