{
  "name": "football-predictor-backend",
  "version": "1.0.0",
  "description": "Football betting prediction engine - Dixon-Coles model",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:migrate:turso": "node scripts/migrate-sqlite-to-turso.js",
    "db:sync:turso": "node scripts/migrate-sqlite-to-turso.js"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "axios": "^1.6.7",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "playwright": "^1.58.2",
    "sql.js": "^1.14.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.33",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
