# Copy this file to .env in the repository root and replace placeholders.
# Do not commit real secrets. Rotate any credentials that were exposed in past commits.

# Core runtime
TZ=Europe/Rome
FRONTEND_PORT=3000
AUTO_SYNC_ON_BOOT=false

# Database
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Odds providers
ODDS_API_KEY=your-odds-api-key
THE_ODDS_API_KEY=your-odds-api-key
SKIP_EUROBET_SCRAPER=false

# Understat scheduler
UNDERSTAT_SCHEDULER_ENABLED=true
UNDERSTAT_SCHEDULER_TIME=01:00
UNDERSTAT_SCHEDULER_MODE=top5
UNDERSTAT_SCHEDULER_COMPETITION=Serie A
UNDERSTAT_SCHEDULER_YEARS_BACK=1
UNDERSTAT_SCHEDULER_IMPORT_PLAYERS=true
UNDERSTAT_SCHEDULER_INCLUDE_MATCH_DETAILS=true
UNDERSTAT_SCHEDULER_FORCE_REFRESH=false
UNDERSTAT_DETAIL_CONCURRENCY=10

# SofaScore supplemental import
SOFASCORE_SUPPLEMENTAL_ENABLED=true
SOFASCORE_SUPPLEMENTAL_MAX_MATCHES_PER_RUN=80
SOFASCORE_REQUEST_TIMEOUT_MS=15000
SOFASCORE_BROWSER_HEADLESS=true
SOFASCORE_BROWSER_SLOW_MO=0

# Odds snapshots
ODDS_SNAPSHOT_SCHEDULER_ENABLED=true
ODDS_SNAPSHOT_SCHEDULER_TIME=02:15
ODDS_SNAPSHOT_RUN_ON_BOOT=false
ODDS_SNAPSHOT_INTERVAL_HOURS=24
ODDS_SNAPSHOT_COMPETITIONS=Serie A,Premier League,La Liga,Bundesliga,Ligue 1
ODDS_SNAPSHOT_MARKETS=h2h,totals,spreads
ODDS_MATCH_CACHE_TTL_SECONDS=180

# Learning reviews
LEARNING_REVIEW_SCHEDULER_ENABLED=true
LEARNING_REVIEW_SCHEDULER_TIME=03:00
LEARNING_REVIEW_RUN_ON_BOOT=false
LEARNING_REVIEW_INTERVAL_HOURS=24
LEARNING_REVIEW_MATCH_LIMIT=50
SCHEDULER_RUN_RETENTION=100

# Eurobet scraper
EUROBET_PERSISTENT_PROFILE_ENABLED=true
EUROBET_PROFILE_DIR=/app/.playwright/eurobet-profile
EUROBET_EVENT_CONCURRENCY=1
EUROBET_BROWSER_HEADLESS=true
EUROBET_BROWSER_CHANNEL=
EUROBET_BROWSER_EXECUTABLE_PATH=
EUROBET_BROWSER_SLOW_MO=300
EUROBET_MATCH_TIMEOUT_MS=60000
ODDS_EVENT_TIMEOUT_MS=45000
ODDS_PROVIDER_MATCH_TIMEOUT_MS=45000
